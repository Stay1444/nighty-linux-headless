# ════════════════════════════════════════════════════════════
#  nighty-linux-headless — configuration
#  Copy to ".env" and fill in.  NEVER commit your real .env.
# ════════════════════════════════════════════════════════════

# ── Your Nighty binary (bring your own — it is NOT redistributed) ──
# Put your original Nighty.exe next to this file, then run scripts/install.sh.
NIGHTY_EXE=./Nighty.exe
NIGHTY_STUB=./Nighty_stub.exe

# ── Runtime locations ──
# scripts/install.sh fills these in for you (resolved, absolute). Defaults below
# are used if you run things manually without the installer.
NIGHTY_HOME=
WINEPREFIX=
# Wine username inside the prefix (drive_c/users/<name>). Leave empty to auto-detect.
WINEUSER=
# Wine launcher binary. On x86-64 this is your distro's "wine64". On non-x86 the
# installer points this at a static x86-64 Wine build that runs under Box64.
WINE_BIN=wine64
# Wine DLL overrides. Default disables the headless-unfriendly components
# (.NET / Internet Explorer / desktop integration) that otherwise crash the
# backend on a fresh prefix. Only change this if you know you need one of them.
# WINEDLLOVERRIDES=mscoree=d;mshtml=d;winemenubuilder.exe=d

# ── Web UI credentials (YOU choose these) ──
WEBUI_USERNAME=admin
WEBUI_PASSWORD=change-this-please

# ── Native Web UI bind (loopback only; the LAN bridge exposes it safely) ──
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8090

# ── LAN bridge (this is the address you open in a browser) ──
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8088

# ── Internal stub control server (loopback only — do not expose) ──
STUB_PORT=8765

# ── Headless virtual display ──
DISPLAY_NUM=99

# ── Hard enforcement: keep Web UI ALWAYS on (1 = enabled) ──
# If Nighty or the user disables Web UI, it is forced back on.
ENFORCE_WEBUI=1
ENFORCE_INTERVAL=5
